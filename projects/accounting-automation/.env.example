TELEGRAM_BOT_TOKEN=8577625613:AAFxqb8WFWLJ4Gcl-9UOiqbPvI_0Uqc9rMs

# Google Sheets Configuration
# 需要建立 Service Account 並下載 credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
