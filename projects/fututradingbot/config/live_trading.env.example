# Futu Live Trading Environment Variables Template
# Copy this file to config/live_trading.env and fill in your actual values
# DO NOT commit live_trading.env to version control!

# ============================================================================
# CRITICAL: Live Trading Safety
# ============================================================================
# Set to 'REAL' only after thoroughly testing in SIMULATE mode
TRADING_MODE=SIMULATE

# ============================================================================
# Futu OpenAPI Authentication (REQUIRED for live trading)
# ============================================================================
# Futu OpenD unlock password (for trading unlock)
FUTU_UNLOCK_PASSWORD=your_unlock_password_here

# Trading account ID (from Futu OpenD)
FUTU_TRD_ACCOUNT=your_account_id_here

# ============================================================================
# Risk Limits (REQUIRED - must be set before live trading)
# ============================================================================
# Maximum daily loss in USD (e.g., 100 = $100 max loss per day)
MAX_DAILY_LOSS=100

# Maximum position size as percentage of total capital (e.g., 20 = 20%)
MAX_POSITION_PERCENT=20

# Stop loss percentage (e.g., 5 = 5% stop loss)
STOP_LOSS_PERCENT=5

# Take profit percentage (e.g., 10 = 10% take profit)
TAKE_PROFIT_PERCENT=10

# Maximum number of trades per day
MAX_DAILY_TRADES=10

# ============================================================================
# WhatsApp/Telegram Notifications (Optional but recommended)
# ============================================================================
# WhatsApp Business API (using Twilio)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+your_phone_number

# Telegram (alternative)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================================================
# Monitoring & Alerts
# ============================================================================
# Enable real-time monitoring
MONITORING_ENABLED=true

# Monitoring interval in seconds
MONITOR_INTERVAL=30

# Alert on position changes > X%
POSITION_ALERT_THRESHOLD=10

# Alert on P&L changes > X%
PNL_ALERT_THRESHOLD=5