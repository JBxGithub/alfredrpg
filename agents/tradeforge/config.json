{
  "agent": {
    "id": "tradeforge",
    "name": "Catwoman TradeForge",
    "type": "subagent",
    "parent": "main"
  },
  "communication": {
    "upstream": ["main", "signalseorge"],
    "downstream": [],
    "methods": {
      "receive": ["sessions_send", "shared_memory"],
      "send": ["sessions_send", "shared_memory", "webhook"]
    }
  },
  "trading": {
    "mode": "paper",
    "account": "simulated",
    "symbols": ["TQQQ"],
    "order_types": ["MARKET", "LIMIT"]
  },
  "risk_management": {
    "max_position_size": 0.50,
    "max_total_exposure": 1.00,
    "daily_var_limit": 0.02,
    "take_profit": 0.05,
    "stop_loss": 0.03,
    "time_stop_days": 3
  },
  "execution": {
    "slippage_tolerance": 0.001,
    "max_order_delay_ms": 2000,
    "partial_fill_acceptance": true
  },
  "dashboard": {
    "enabled": true,
    "port": 8501,
    "refresh_interval": 5
  },
  "logging": {
    "level": "INFO",
    "path": "~/openclaw_workspace/agents/tradeforge/logs/",
    "trade_log": "trades.csv"
  }
}
