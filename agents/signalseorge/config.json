{
  "agent": {
    "id": "signalseorge",
    "name": "BatGirl SignalForge",
    "type": "subagent",
    "parent": "main"
  },
  "communication": {
    "upstream": ["main", "dataforge"],
    "downstream": ["tradeforge"],
    "methods": {
      "receive": ["sessions_send", "shared_memory"],
      "send": ["sessions_send", "shared_memory", "webhook"]
    }
  },
  "strategy": {
    "name": "TQQQ Z-Score Mean Reversion",
    "parameters": {
      "zscore_threshold": 1.6,
      "rsi_overbought": 70,
      "rsi_oversold": 30,
      "take_profit": 0.05,
      "stop_loss": 0.03,
      "time_stop": 3,
      "position_size": 0.50
    }
  },
  "signals": {
    "types": ["LONG", "SHORT", "HOLD"],
    "strength_levels": ["WEAK", "MODERATE", "STRONG"],
    "confirmation_required": true
  },
  "backtest": {
    "enabled": true,
    "auto_run": "daily",
    "history_period": "3y"
  },
  "logging": {
    "level": "INFO",
    "path": "~/openclaw_workspace/agents/signalseorge/logs/"
  }
}
