{
  "agent": {
    "id": "dataforge",
    "name": "Robin DataForge",
    "type": "subagent",
    "parent": "main"
  },
  "communication": {
    "upstream": ["main"],
    "downstream": ["signalseorge"],
    "methods": {
      "receive": ["sessions_send", "shared_memory"],
      "send": ["sessions_send", "shared_memory", "webhook"]
    }
  },
  "data_pipeline": {
    "input": {
      "source": "Futu Open API",
      "symbols": ["TQQQ"],
      "intervals": ["1m", "5m", "1d"]
    },
    "output": {
      "format": "json",
      "destination": "shared_memory",
      "path": "~/openclaw_workspace/agents/shared/data/"
    }
  },
  "indicators": {
    "calculate": ["zscore", "rsi", "macd", "volume_ma"],
    "update_interval": 60
  },
  "logging": {
    "level": "INFO",
    "path": "~/openclaw_workspace/agents/dataforge/logs/"
  }
}
