{
  "version": "Professional_MTF_v1.0",
  "description": "FutuTradingBot 專業級 MTF 交易系統配置",
  "last_updated": "2026-04-23",
  
  "trading": {
    "symbol": "QQQ",
    "leveraged_long": "TQQQ",
    "leveraged_short": "SQQQ",
    "vix_symbol": "^VIX",
    "market": "US"
  },
  
  "timeframes": {
    "monthly": {
      "description": "最終趨勢濾網，絕不逆月線大勢",
      "weight": 0.4,
      "min_data_points": 50
    },
    "weekly": {
      "description": "中級趨勢確認",
      "weight": 0.35,
      "min_data_points": 20,
      "conditions": {
        "adx_above": 20,
        "price_above_ema20": true
      }
    },
    "daily": {
      "description": "入場執行層",
      "weight": 0.25,
      "min_data_points": 50
    }
  },
  
  "indicators": {
    "adx": {
      "period": 14,
      "thresholds": {
        "no_trend": 20,
        "weak": 25,
        "strong": 50,
        "extreme": 70
      }
    },
    "macd": {
      "fast": 12,
      "slow": 26,
      "signal": 9
    },
    "ema": {
      "periods": [9, 20, 50]
    },
    "bollinger": {
      "period": 20,
      "std_dev": 2
    },
    "atr": {
      "period": 14,
      "stop_loss_multiplier": 1.5
    },
    "volume": {
      "period": 20,
      "threshold": 1.5
    },
    "rsi": {
      "period": 14,
      "overbought": 70,
      "oversold": 30
    }
  },
  
  "entry_conditions": {
    "long": {
      "description": "多頭入場條件 (全部必須滿足)",
      "conditions": {
        "adx_above_25": true,
        "adx_rising": true,
        "plus_di_above_minus_di": true,
        "macd_golden_cross": true,
        "price_above_ema20": true,
        "volume_spike": true,
        "rsi_not_overbought": true
      },
      "mtf_requirements": {
        "monthly_bullish": true,
        "weekly_bullish": true,
        "daily_all_met": true
      }
    },
    "short": {
      "description": "空頭入場條件 (全部必須滿足)",
      "conditions": {
        "adx_above_25": true,
        "adx_rising": true,
        "minus_di_above_plus_di": true,
        "macd_death_cross": true,
        "price_below_ema20": true,
        "volume_spike": true,
        "rsi_not_oversold": true
      },
      "mtf_requirements": {
        "monthly_bearish": true,
        "weekly_bearish": true,
        "daily_all_met": true
      }
    }
  },
  
  "exit_conditions": {
    "stop_loss": {
      "type": "atr",
      "multiplier": 1.5,
      "description": "ATR 1.5倍止損"
    },
    "take_profit": {
      "risk_reward_ratio": 2.0,
      "description": "風險報酬比 1:2"
    },
    "trailing_stop": {
      "type": "ema20",
      "description": "跟隨20EMA"
    },
    "macd_reversal": {
      "enabled": true,
      "description": "MACD反轉平倉"
    },
    "adx_fatigue": {
      "enabled": true,
      "from_level": 50,
      "description": "ADX從>50回落平倉"
    }
  },
  
  "risk_management": {
    "max_risk_per_trade": 0.01,
    "max_daily_loss": 0.02,
    "max_consecutive_losses": 2,
    "max_open_positions": 3,
    "max_total_risk": 0.04,
    
    "vix_adjustment": {
      "high_threshold": 25,
      "extreme_threshold": 30,
      "high_risk_factor": 0.5,
      "extreme_action": "halt_trading"
    },
    
    "emergency_rules": {
      "single_day_drop": {
        "threshold": 0.05,
        "action": "reduce_50_percent",
        "description": "單日>5%強制減倉50%"
      },
      "consecutive_losses": {
        "count": 2,
        "action": "halt_trading_for_day",
        "description": "連續虧損2筆當日停手"
      }
    }
  },
  
  "consolidation_mode": {
    "trigger": {
      "adx_below": 20,
      "description": "ADX < 20 進入盤整模式"
    },
    "strategy": {
      "type": "mean_reversion",
      "long_condition": "價格觸碰BOLL下軌 + RSI < 30",
      "short_condition": "價格觸碰BOLL上軌 + RSI > 70",
      "target": "BOLL中軌"
    }
