# Futu Trading Bot - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================================================
# Futu OpenAPI Authentication
# ============================================================================
# Futu OpenD unlock password (for trading unlock)
FUTU_UNLOCK_PASSWORD=your_unlock_password_here

# Trading account ID
FUTU_TRD_ACCOUNT=your_account_id_here

# ============================================================================
# Web Dashboard Authentication (Optional)
# ============================================================================
WEB_USERNAME=admin
WEB_PASSWORD=change_this_password

# ============================================================================
# Telegram Notifications (Optional)
# ============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================================
# Email Notifications (Optional)
# ============================================================================
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_TO_ADDRESS=recipient@example.com
