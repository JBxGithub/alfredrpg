  "notes": {
    "core_principle": "絕不逆月線大勢",
    "mtf_hierarchy": "月線 > 周線 > 日線",
    "risk_priority": "風險控制優於收益追求",
    "discipline": "嚴格遵守止損和風險規則"
  }
